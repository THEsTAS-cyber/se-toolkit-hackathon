# Backend Environment Variables

# Application
NAME=ProjectSET Backend
DEBUG=false
ADDRESS=0.0.0.0
PORT=8000
RELOAD=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Database
DB_HOST=postgres
DB_PORT=5432
